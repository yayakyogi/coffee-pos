# ── Application ──────────────────────────────
APP_PORT=8080
APP_ENV=development

# ── MySQL (app connection) ───────────────────
# DB_PASSWORD must match MYSQL_ROOT_PASSWORD below.
# DB_NAME must match MYSQL_DATABASE below.
DB_HOST=localhost
DB_PORT=3306
DB_NAME=coffee_pos
DB_USER=root
DB_PASSWORD=

# ── Redis ────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT ──────────────────────────────────────
JWT_SECRET=your-secret-key-minimum-32-characters
JWT_EXPIRY_HOURS=24

# ── Midtrans ─────────────────────────────────
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_ENV=sandbox

# ── Docker Compose (MySQL container init) ────
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=coffee_pos
